rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    match /sistemas/{sistemaId} {
      allow read, write: if true;
    }

    match /clientes/{clienteId} {
      allow read, create, update, delete: if signedIn();
    }

    match /servicos/{servicoId} {
      allow read, create, update, delete: if signedIn();
    }

    match /agendamentos/{agendamentoId} {
      allow read: if signedIn();
      allow create, update: if signedIn()
        && request.resource.data.valorServico is number
        && request.resource.data.valorServico > 0
        && request.resource.data.valorFinal is number
        && request.resource.data.valorFinal >= 0
        && request.resource.data.status in ['Agendado', 'Confirmado', 'Concluído', 'Cancelado']
        && request.resource.data.descontoTipo in ['nenhum', 'valor', 'porcentagem'];
      allow delete: if signedIn();
    }

    match /financeiro/{financeiroId} {
      allow read: if signedIn();
      allow create, update: if signedIn()
        && request.resource.data.tipo in ['entrada', 'saida']
        && request.resource.data.origem in ['manual', 'agendamento']
        && request.resource.data.valor is number
        && request.resource.data.valor >= 0;
      allow delete: if signedIn();
    }
  }
}
